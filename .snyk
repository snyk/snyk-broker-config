# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  SNYK-JS-PICOMATCH-15765511:
    - '*':
        reason: >-
          picomatch is bundled inside npm@11.18.0 (latest) via
          node-gyp > tinyglobby. Bundled dependencies cannot be overridden; no
          fix is available until npm ships an updated node-gyp. Not reachable
          through this CLI's usage.
        expires: 2026-10-15T00:00:00.000Z
        created: 2026-07-15T00:00:00.000Z
  SNYK-JS-PICOMATCH-15765513:
    - '*':
        reason: >-
          picomatch is bundled inside npm@11.18.0 (latest) via
          node-gyp > tinyglobby. Bundled dependencies cannot be overridden; no
          fix is available until npm ships an updated node-gyp. Not reachable
          through this CLI's usage.
        expires: 2026-10-15T00:00:00.000Z
        created: 2026-07-15T00:00:00.000Z
  SNYK-JS-YARN-12143051:
    - '*':
        reason: >-
          yarn 1.x is end-of-life with no patched release. Bundled by
          @oclif/plugin-plugins for optional plugin installs; the ReDoS is not
          reachable through this CLI's usage.
        expires: 2026-10-15T00:00:00.000Z
        created: 2026-07-15T00:00:00.000Z
