{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "module": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "es2022",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "moduleResolution": "node16",
    "types": ["node"]
  },
  "include": ["./src/**/*"],
  "ts-node": {
    "esm": true,
    "compilerOptions": {
      "types": ["node", "mocha"]
    }
  }
}
